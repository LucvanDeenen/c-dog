{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    
    /* Path matching */
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@electron/*": [
        "./electron/*"
      ],
      "@shared/*": [
        "./shared/*"
      ],
      "@util/*": [
        "./util/*"
      ]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue", "electron", "electron/**/*.ts", "shared", "util"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
